# ─────────────────────────────────────────────────
# PCG Starter — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local
# ─────────────────────────────────────────────────

# Production domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.myclient.com

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Contact form email transport
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_FORM_TO=hello@myclient.com
