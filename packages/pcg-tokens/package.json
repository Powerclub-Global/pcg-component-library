{
  "name": "@powerclub-global/tokens",
  "version": "1.0.0",
  "description": "Unified design tokens for PowerClub Global ecosystem",
  "main": "index.ts",
  "types": "types.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Powerclub-Global/pcg-component-library.git",
    "directory": "packages/pcg-tokens"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "exports": {
    ".": "./index.ts",
    "./css/*": "./css/*",
    "./tailwind-preset": "./tailwind-preset.ts"
  },
  "files": ["css/", "tailwind-preset.ts", "index.ts", "types.ts"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  }
}
